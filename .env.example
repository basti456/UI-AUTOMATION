# Unified QA Crawler Configuration

# Basic Settings
START_URL=https://playwright.dev/
MAX_PAGES=50
MAX_DEPTH=3

# Mode Settings
INTERACTIVE_MODE=false
HEADLESS=true

# QA Features (set to false to disable)
ENABLE_VISUAL_REGRESSION=true
ENABLE_ACCESSIBILITY=true
ENABLE_LINK_VALIDATION=true
ENABLE_JS_ERROR_DETECTION=true
ENABLE_PERFORMANCE=true
ENABLE_SEO=true

# Visual Regression Settings
BASELINE_DIR=screenshots/baseline
DIFF_THRESHOLD=0.1

# Report Settings
REPORT_DIR=qa-reports
GENERATE_HTML_REPORT=true
